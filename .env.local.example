# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=
TWILIO_MESSAGING_SID=

# VAPID (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@heyfam.blog

# Email (Postmark)
POSTMARK_TOKEN=
POSTMARK_FROM=notifications@heyfam.blog

# Local dev email viewer (see docs/dev/notifications.md)
# - mailpit : send via 127.0.0.1:1025, view at http://localhost:8025
# - log     : write the body to error_log (works without Mailpit)
# - (unset) : default WP mailer (likely /dev/null on Studio)
HEYFAM_DEV_MAIL=mailpit

# App
HEYFAM_INVITE_HMAC_SECRET=
