{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "palette": [
        { "slug": "bg",       "name": "Background", "color": "#fffaf3" },
        { "slug": "fg",       "name": "Foreground", "color": "#1f1d1a" },
        { "slug": "accent",   "name": "Accent",     "color": "#d97706" },
        { "slug": "muted",    "name": "Muted",      "color": "#7a716a" },
        { "slug": "surface",  "name": "Surface",    "color": "#fffefb" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
          "name": "System",
          "slug": "system"
        }
      ],
      "fontSizes": [
        { "slug": "small",  "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1rem",     "name": "Medium" },
        { "slug": "large",  "size": "1.25rem",  "name": "Large" }
      ]
    },
    "layout": { "contentSize": "640px", "wideSize": "960px" }
  },
  "styles": {
    "color": { "background": "var(--wp--preset--color--bg)", "text": "var(--wp--preset--color--fg)" },
    "typography": { "fontFamily": "var(--wp--preset--font-family--system)", "fontSize": "var(--wp--preset--font-size--medium)" }
  },
  "templateParts": [
    { "name": "header",         "title": "Header",         "area": "header" },
    { "name": "fam-picker",     "title": "Fam Picker",     "area": "uncategorized" },
    { "name": "composer",       "title": "Composer",       "area": "uncategorized" },
    { "name": "post-card",      "title": "Post Card",      "area": "uncategorized" },
    { "name": "comment-thread", "title": "Comment Thread", "area": "uncategorized" }
  ],
  "customTemplates": [
    { "name": "page-feed",    "title": "Fam Feed",        "postTypes": [ "page" ] },
    { "name": "page-account", "title": "Account Settings","postTypes": [ "page" ] }
  ]
}
